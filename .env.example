# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Configuration (MongoDB Atlas)
MONGO_DB_NAME=allflex_db
MONGO_DB_USER=allflex_user
MONGO_DB_PASSWORD=your-mongodb-password-here
MONGO_DB_HOST=your-cluster.xxxxx.mongodb.net
# Optional: Full connection string (if you prefer to use this instead of individual vars)
# MONGO_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/allflex_db?retryWrites=true&w=majority

# Database Mode: 'mongodb' or 'sqlite' (for testing)
DATABASE_MODE=mongodb

# Optional: Google Gemini API for gym finder (leave unset to show "set GEMINI_API_KEY" message)
# GEMINI_API_KEY=your-gemini-api-key
